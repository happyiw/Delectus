          <argument>
            <kind>1</kind>
            <string>list=ds_list_create()

with(objBlock) {
    ds_list_add(other.list,id)
}

with(objPlayerKiller) {
    ds_list_add(other.list,id)
}

with(objWater) {
    ds_list_add(other.list,id)
}
with(objWater2) {
    ds_list_add(other.list,id)
}
with(objSave) {
    ds_list_add(other.list,id)
}
with(objSign) {

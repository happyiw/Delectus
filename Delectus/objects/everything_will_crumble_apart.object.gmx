    <event eventtype="3" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>t++

if t&lt;=50 {
    with(objFreeTrigger) {
        image_alpha-=0.02
        if image_alpha&lt;=0
            instance_destroy()
    }
}

if t&gt;=50 {
   
    
    with(all) {
        _id=ds_list_find_index(other.list,id)
        if _id!=-1 {
            x=xstart+random(clamp((other.t-50)/130,0,3))*choose(-1,1)
            y=ystart+random(clamp((other.t-50)/130,0,3))*choose(-1,1)
        
        }
    }
    if t&gt;=150 {
        if ds_list_size(list)!=0 {
            timer--;
            if timer==0 {
                repeat(irandom_range(1,6)) {
                    if ds_list_size(list)!=0 {
                        _id=ds_list_find_value(list,0)
                        
                        with(all) {
                            if id==other._id {
                                a=instance_create(x,y,idk)
                                a.sprite_index=sprite_index;
                                a.gravity=random_range(0.2,0.4)
                                a.image_speed=0
                                a.depth=depth
                                a.image_xscale=image_xscale;
                                a.image_yscale=image_yscale;
                                instance_destroy()
                            }
                        }
                        
                        ds_list_delete(list,0)
                    }
                }
                
                timer=irandom_range(5,10)
            }
        }
        else {
            /*
            if timer!=-1 {
                alarm[0]=100
                timer=-1
            }
            */
            if !instance_exists(idk) and timer!=-1 {
                alarm[0]=20
                timer=-1
            }
        }
        
    }
}
</string>
          </argument>
        </arguments>
      </action>

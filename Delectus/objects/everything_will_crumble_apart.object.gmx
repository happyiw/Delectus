    ds_list_add(other.list,id)
}
with(objVineR) {
    ds_list_add(other.list,id)
}
with(objPlatform) {
    ds_list_add(other.list,id)
}

ds_list_shuffle(list)

timer=irandom_range(10,20)
t=0
